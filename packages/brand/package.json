{
  "name": "@behindthemusictree/brand",
  "version": "11.4.3",
  "description": "Shared assets (components, tokens, marks, styles) for React projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/BehindTheMusicTree/the-music-tree-brand.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./components": "./dist/components/index.js",
    "./components/*": "./dist/components/*",
    "./marks/*": "./src/marks/*",
    "./favicons/*": "./src/favicons/*",
    "./banners/*": "./src/banners/*",
    "./tokens/*": "./dist/tokens/*",
    "./styles": "./src/styles/index.css",
    "./styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src/marks",
    "src/styles",
    "src/favicons",
    "src/banners",
    "docs",
    "src/banners/README.md",
    "src/marks/README.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "author": "Andreas Garcia",
  "license": "ISC"
}
