{
  // Main launch flow: run build+server tasks, then open browser on the strict Vite port.
  // Library watch (`pnpm run dev` / tsup --watch) is separate; it does not start the UI.
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Playground: build then dev server (opens browser)",
      "preLaunchTask": "playground: build + serve",
      "url": "http://localhost:5174",
      "webRoot": "${workspaceFolder}/playground"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Playground: Vite only (opens browser)",
      "preLaunchTask": "playground: dev server",
      "url": "http://localhost:5174",
      "webRoot": "${workspaceFolder}/playground"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Library: tsup watch (no browser)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Chrome: playground (server already running)",
      "url": "http://localhost:5174",
      "webRoot": "${workspaceFolder}/playground"
    }
  ]
}
