{
  "name": "@behindthemusictree/assets",
  "version": "11.2.0",
  "description": "Shared assets (components, tokens, brand artwork, styles) for React projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/BehindTheMusicTree/organization-assets.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs"
    },
    "./brand": {
      "types": "./dist/brand/index.d.ts",
      "import": "./dist/brand/index.js",
      "require": "./dist/brand/index.cjs"
    },
    "./brand/audio-fingerprinter/*": "./dist/brand/audio-fingerprinter/*",
    "./brand/audiometa/*": "./dist/brand/audiometa/*",
    "./brand/behind-the-music-tree/*": "./dist/brand/behind-the-music-tree/*",
    "./brand/grow-the-music-tree/*": "./dist/brand/grow-the-music-tree/*",
    "./brand/hear-the-music-tree/*": "./dist/brand/hear-the-music-tree/*",
    "./brand/the-music-deck/*": "./dist/brand/the-music-deck/*",
    "./brand/the-music-tree/*": "./dist/brand/the-music-tree/*",
    "./favicons/*": "./dist/favicons/*",
    "./banners/*": "./dist/banners/*",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./styles": "./dist/styles/index.css",
    "./styles/icon-links.css": "./dist/styles/icon-links.css",
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "src/banners/README.md",
    "src/brand/README.md"
  ],
  "scripts": {
    "build": "node scripts/assert-org-url.mjs && tsup && cp src/tokens/*.css dist/tokens/ && cp -r src/styles dist/ && cp -r src/brand/audio-fingerprinter src/brand/audiometa src/brand/behind-the-music-tree src/brand/grow-the-music-tree src/brand/hear-the-music-tree src/brand/the-music-deck src/brand/the-music-tree dist/brand/ && cp -r src/favicons dist/ && mkdir -p dist/banners && find src/banners -mindepth 1 -maxdepth 1 -type d -exec cp -r {} dist/banners/ \\;",
    "dev": "node scripts/assert-org-url.mjs && tsup --watch",
    "playground": "node scripts/run-playground.mjs",
    "playground:dev": "npm run dev --prefix playground",
    "playground:install": "npm install --prefix playground",
    "test": "echo \"Error: no test specified\" && exit 1",
    "release": "bash scripts/release.sh"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "react",
    "components",
    "design-tokens",
    "shared-assets"
  ],
  "author": "",
  "license": "ISC"
}
