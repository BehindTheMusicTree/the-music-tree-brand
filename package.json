{
  "name": "@behindthemusictree/assets",
  "version": "11.4.3",
  "description": "Shared assets (components, tokens, brand artwork, styles) for React projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/BehindTheMusicTree/organization-assets.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./components": "./dist/components/index.js",
    "./components/*": "./dist/components/*",
    "./brand/*": "./dist/brand/*",
    "./tokens/*": "./dist/tokens/*",
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist",
    "docs",
    "src/banners/README.md",
    "src/brand/README.md"
  ],
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "copy-assets": "rsync -av --include='*/' --include='*.css' --include='*.svg' --include='*.png' --include='*.ico' --exclude='*' src/ dist/",
    "copy-assets:watch": "pnpm copy-assets && pnpm chokidar \"src/**/*.{png,svg,css}\" -c \"pnpm copy-assets\"",
    "build": "node scripts/assert-org-url.mjs && tsup && pnpm copy-assets",
    "dev:lib": "pnpm build && concurrently \"tsup --watch\" \"pnpm copy-assets:watch\"",
    "dev:app": "pnpm -C playground dev",
    "dev:all": "pnpm build && concurrently \"pnpm dev:lib\" \"pnpm --dir playground dev\"",
    "playground": "node scripts/run-playground.mjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "release": "bash scripts/release.sh"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "keywords": [
    "react",
    "components",
    "design-tokens",
    "shared-assets"
  ],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "playground"
  ]
}
