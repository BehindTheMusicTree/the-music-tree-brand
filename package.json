{
  "name": "the-music-tree-brand",
  "version": "0.0.0",
  "description": "Shared assets for React projects and playground app",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/BehindTheMusicTree/the-music-tree-brand.git"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @themusictree/brand --filter playground dev",
    "build": "pnpm -r build",
    "release": "bash scripts/release.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "keywords": [
    "react",
    "components",
    "design-tokens",
    "shared-assets"
  ],
  "author": "Andreas Garcia",
  "license": "ISC"
}
