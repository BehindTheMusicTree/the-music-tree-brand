# Required for root `pnpm run build` / `pnpm run dev` / `pnpm run playground`
# (scripts/assert-org-url.mjs + tsup + playground Vite). Shell overrides these values.
# CI: map each key to a GitHub repository variable of the same name (see publish.yml).

# Same as repository variable DOMAIN_NAME in publish workflow (hostname, no protocol).
ORG_DOMAIN=themusictree.org

# Organization name (e.g. BehindTheMusicTree)
ORG_NAME=BehindTheMusicTree

ORG_GITHUB_SPONSOR_BUTTON_URL=https://github.com/sponsors/BehindTheMusicTree/button
ORG_GITHUB_URL=https://github.com/BehindTheMusicTree
HTMT_API_REPO_NAME=hear-the-music-tree-api
ORG_PYPI_URL=https://pypi.org/project/example/
ORG_LINKEDIN_URL=https://www.linkedin.com/in/your-handle
ORG_X_URL=https://x.com/your-handle
ORG_MASTODON_URL=https://mastodon.social/@yourhandle
ORG_YOUTUBE_URL=https://www.youtube.com/@your-handle
ORG_SPOTIFY_URL=https://open.spotify.com/artist/your-artist-id
ORG_DISCORD_URL=https://discord.gg/your-invite
ORG_TIPEEE_URL=https://www.tipeee.com/your-page
CONTACT_EMAIL=you@example.com
TMD_ADMIN_API_REPO_NAME=the-music-deck-admin-api

# Subdomain labels (inlined into dist via tsup; see socialBuildEnv exports).
HTMT_FRONT_SUBDOMAIN=hear
HTMT_API_SUBDOMAIN=api
GTMT_FRONT_SUBDOMAIN=app
GTMT_API_SUBDOMAIN=grow-api
AUDIOMETA_FRONT_SUBDOMAIN=audiometa
AUDIOMETA_API_SUBDOMAIN=audiometa-api
TMTA_SUBDOMAIN=api
TMD_GAME_SUBDOMAIN=deck
TMD_SHOWCASE_SUBDOMAIN=deck-showcase
